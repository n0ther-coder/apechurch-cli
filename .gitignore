# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'

# Ignore commit message
commit.txt

# Regen with `npm ci`
node_modules

# Ignore all logfiles and tempfiles, but keep the directories.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore test tmp directories.
tests/tmp-*/

# Ignore temporary craps
*~

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# robots.txt should be ignored when pushing to heroku because it breaks the server!
robots.txt

# Ignore stupid files
.DS_Store

# Folders for stuff that should stay local and must not be propagated
/_disabled
/_unversioned_data/
/_local_only/*
!/_local_only/.keep